<odoo>
    <record id="module_category_sale_approval" model="ir.module.category">
        <field name="name">Sale Order Approval</field>
        <field name="description">Manage multi-level approval for sale orders.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_sale_order_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="Sale_Order_Approval.module_category_sale_approval"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_sale_order_director" model="res.groups">
        <field name="name">Director</field>
        <field name="category_id" ref="Sale_Order_Approval.module_category_sale_approval"/>
        <field name="implied_ids" eval="[(4, ref('Sale_Order_Approval.group_sale_order_manager'))]"/>
    </record>
</odoo>

<odoo>
    <record id="res_config_settings_view_form_sale_approval" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sale.approval</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <setting id="order_default_values" position="after">
                <setting
                    id="sale_order_approval_threshold"
                    string="Sale Order Approval"
                    help="Require Manager and Director approval when a quotation total is above the threshold.">
                    <div class="content-group">
                        <div class="mt16">
                            <label for="sale_approval_threshold" class="o_light_label"/>
                            <field name="sale_approval_threshold" class="oe_inline"/>
                        </div>
                    </div>
                </setting>
            </setting>
        </field>
    </record>
</odoo>
